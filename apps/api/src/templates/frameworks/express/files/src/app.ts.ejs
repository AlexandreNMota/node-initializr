<% if (isTypeScript) { %>
    import express from 'express';
    
    import { router } from './routes/index.js';
    <% if (dependencies.includes('swagger')) { %>
        import { setupSwagger } from './docs/setupSwagger.js';
        <% } %>
    
    export const app = express();
    
    app.use(express.json());
    <% if (dependencies.includes('swagger')) { %>
        setupSwagger(app);
        <% } %>
    
    app.use('/api', router);
    <% } %>